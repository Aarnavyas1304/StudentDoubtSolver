@model IEnumerable<StudentDoubtSolver.Models.Question>
@using Microsoft.AspNetCore.Http

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | Student Brain Trust</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --login-grad: linear-gradient(135deg, #1e3c72 0%, #2a5298 50%, #702082 100%);
            --glass-base: rgba(255, 255, 255, 0.75);
            --header-dark: rgba(30, 60, 114, 0.98);
        }

        body { 
            background: radial-gradient(circle at top left, #fdfcfb 0%, #e2d1c3 100%);
            font-family: 'Poppins', sans-serif; 
            margin: 0;
            padding-top: 120px; 
            min-height: 100vh; 
        }
        
        /* The Floating Command Header */
        .floating-nav {
            background: var(--header-dark);
            backdrop-filter: blur(20px);
            height: 85px; width: 92%; position: fixed; top: 15px; left: 4%;
            border-radius: 50px; z-index: 1000; display: flex; align-items: center; 
            justify-content: space-between; padding: 0 30px;
            box-shadow: 0 15px 35px rgba(30, 60, 114, 0.3);
            border: 1px solid rgba(255,255,255,0.1);
        }

        /* Bubbly Search Bar */
        .search-pill-box {
            background: rgba(255, 255, 255, 0.12);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 50px;
            padding: 10px 25px;
            color: white;
            transition: 0.3s;
            width: 100%;
            max-width: 400px;
        }
        .search-pill-box:focus {
            background: rgba(255, 255, 255, 0.2);
            outline: none;
            box-shadow: 0 0 15px rgba(255, 255, 255, 0.1);
        }
        .search-pill-box::placeholder { color: rgba(255, 255, 255, 0.5); }

        /* Bitmoji Profile */
        .bitmoji-circle {
            width: 48px; height: 48px; background: white; border-radius: 50%;
            padding: 2px; transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        .bitmoji-circle:hover { transform: scale(1.15) rotate(10deg); }
        
        /* The Bubbly Question Cards */
        .q-bubble-card { 
            background: var(--glass-base); 
            border-radius: 40px; 
            padding: 40px; 
            margin-bottom: 30px; 
            border: 1px solid rgba(255,255,255,0.8); 
            box-shadow: 0 10px 30px rgba(0,0,0,0.03);
            transition: all 0.4s ease;
            backdrop-filter: blur(10px);
            position: relative;
        }
        .q-bubble-card:hover { transform: translateY(-8px); box-shadow: 0 20px 50px rgba(0,0,0,0.07); }

        /* Danger Zone Button */
        .delete-icon-btn {
            position: absolute; top: 25px; right: 25px;
            background: #fff5f5; color: #ff4d4d; border: none;
            width: 42px; height: 42px; border-radius: 15px;
            transition: 0.3s; display: flex; align-items: center; justify-content: center;
        }
        .delete-icon-btn:hover { background: #ff4d4d; color: white; transform: scale(1.1) rotate(5deg); }

        .btn-gradient-post {
            background: var(--login-grad); color: white; border: none;
            border-radius: 50px; padding: 14px 35px; font-weight: 700;
            box-shadow: 0 10px 20px rgba(112, 32, 130, 0.2);
            transition: 0.3s;
        }
        .btn-gradient-post:hover { transform: translateY(-2px); color: white; opacity: 0.9; }

        .point-badge {
            background: #eef2ff; color: #1e3c72; font-weight: 800;
            padding: 8px 20px; border-radius: 50px; font-size: 0.85rem;
        }
    </style>
</head>
<body>

<header class="floating-nav">
    <div class="text-white d-flex align-items-center d-none d-lg-flex">
        <i class="bi bi-mortarboard-fill fs-3 me-2"></i>
        <span class="fw-bold fs-4">Brain Trust</span>
    </div>

    <div class="flex-grow-1 mx-lg-5 mx-2">
        <form asp-action="Index" method="get" class="position-relative">
            <input type="text" name="searchString" class="search-pill-box w-100" placeholder="Search doubts..." value="@ViewData["CurrentFilter"]">
            <button type="submit" class="position-absolute end-0 top-50 translate-middle-y border-0 bg-transparent pe-3 text-white">
                <i class="bi bi-search"></i>
            </button>
        </form>
    </div>
    
    <div class="d-flex align-items-center">
        @{ var userSeed = Context.Session.GetString("UserName") ?? "Scholar"; }
        <a asp-controller="Profile" asp-action="Index" class="text-decoration-none d-flex align-items-center me-3">
            <div class="bitmoji-circle me-2 shadow-sm">
                <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=@userSeed" width="44" height="44" class="rounded-circle">
            </div>
            <span class="text-white fw-bold d-none d-sm-inline small">@userSeed</span>
        </a>
        <a asp-controller="Account" asp-action="Logout" class="btn btn-sm btn-outline-light rounded-pill px-3 fw-bold">Logout</a>
    </div>
</header>

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-5 px-2">
        <div>
            <h1 class="fw-800 text-dark mb-0" style="letter-spacing: -1.5px;">Student Exchange</h1>
            <p class="text-muted fw-medium">Active doubts from your fellow scholars.</p>
        </div>
        <a asp-action="Create" class="btn btn-gradient-post">
            <i class="bi bi-plus-circle-fill me-2"></i>Post Doubt
        </a>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-12">
                    <div class="q-bubble-card">
                        <form asp-action="DeleteQuestion" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Archive this doubt permanently?');">
                            <button type="submit" class="delete-icon-btn shadow-sm">
                                <i class="bi bi-trash3-fill fs-5"></i>
                            </button>
                        </form>

                        <div class="row align-items-center">
                            <div class="col-lg-9">
                                <span class="badge bg-white text-primary border rounded-pill mb-3 px-3 py-2 fw-bold">Target Doubt #@item.Id</span>
                                <h2 class="fw-bold text-dark">@item.Title</h2>
                                <p class="text-secondary fw-medium fs-5">@item.Description</p>
                            </div>
                            <div class="col-lg-3 text-lg-end mt-4 mt-lg-0 border-start ps-lg-5">
                                <div class="mb-4">
                                    <span class="point-badge shadow-sm">
                                        <i class="bi bi-star-fill text-warning me-1"></i> @item.Votes Points
                                    </span>
                                </div>
                                <a asp-action="ProvideSolution" asp-route-id="@item.Id" class="btn btn-dark rounded-pill px-4 py-2 fw-bold w-100 shadow">
                                    Solve Doubt <i class="bi bi-chevron-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

</body>
</html>