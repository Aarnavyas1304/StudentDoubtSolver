@model StudentDoubtSolver.Models.RegisterViewModel

@{
    ViewData["Title"] = "Join the Community";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="row g-0">
                    <div class="col-md-5 d-none d-md-flex flex-column justify-content-center text-white p-5"
                         style="background: linear-gradient(135deg, #a855f7 0%, #6366f1 100%);">
                        <h2 class="fw-bold">Join the Brain Trust</h2>
                        <ul class="list-unstyled mt-4">
                            <li class="mb-3"><i class="bi bi-check-circle-fill me-2"></i> Get answers from experts</li>
                            <li class="mb-3"><i class="bi bi-check-circle-fill me-2"></i> Build your reputation</li>
                            <li class="mb-3"><i class="bi bi-check-circle-fill me-2"></i> Help fellow students</li>
                        </ul>
                    </div>

                    <div class="col-md-7 bg-white p-5">
                        <h3 class="fw-bold mb-4">Create Account</h3>
                        
                        <form asp-action="Register" method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

                            <div class="mb-3">
                                <label asp-for="UserName" class="form-label small fw-bold text-muted">Full Name</label>
                                <input asp-for="UserName" class="form-control rounded-pill border-light bg-light px-3" placeholder="Aarna Vyas" />
                                <span asp-validation-for="UserName" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Email" class="form-label small fw-bold text-muted"></label>
                                <input asp-for="Email" class="form-control rounded-pill border-light bg-light px-3" placeholder="name@example.com" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Password" class="form-label small fw-bold text-muted"></label>
                                    <input asp-for="Password" class="form-control rounded-pill border-light bg-light px-3" />
                                    <span asp-validation-for="Password" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6 mb-4">
                                    <label asp-for="ConfirmPassword" class="form-label small fw-bold text-muted"></label>
                                    <input asp-for="ConfirmPassword" class="form-control rounded-pill border-light bg-light px-3" />
                                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-bold shadow-sm"
                                    style="background: linear-gradient(to right, #a855f7, #6366f1); border: none;">
                                Create My Account
                            </button>

                            <div class="text-center mt-4">
                                <p class="small text-muted">
                                    Already have an account?
                                    <a asp-action="Login" class="text-primary fw-bold text-decoration-none">Login Here</a>
                                </p>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>