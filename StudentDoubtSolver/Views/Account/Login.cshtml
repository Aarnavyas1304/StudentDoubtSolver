@model StudentDoubtSolver.Models.User
@{ Layout = null; }

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Login - Student Brain Trust</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <style>
        body { font-family: 'Poppins', sans-serif; margin: 0; height: 100vh; overflow: hidden; }
        .full-row { height: 100vh; margin: 0; }
        
        .brand-side { 
            background: linear-gradient(160deg, #1e3c72 0%, #2a5298 30%, #702082 70%, #a31a7e 100%); 
            color: white; padding: 8% 10%; display: flex; flex-direction: column;
            justify-content: center;
        }

        .form-control-lg { 
            height: 60px !important; 
            font-size: 1.1rem !important;
            border-radius: 12px !important;
            margin-bottom: 20px;
            border: 2px solid #f1f3f9;
        }
        .form-control-lg:focus {
            border-color: #702082;
            box-shadow: none;
        }

        .btn-login { 
            background: linear-gradient(90deg, #1e3c72 0%, #702082 100%);
            border: none; border-radius: 50px; height: 60px; font-weight: 700; font-size: 1.2rem;
            box-shadow: 0 10px 20px rgba(30, 60, 114, 0.2); transition: 0.3s;
        }
        .btn-login:hover { transform: translateY(-2px); box-shadow: 0 15px 25px rgba(30, 60, 114, 0.3); }

        .btn-google { 
            border: 1px solid #ddd; height: 55px; border-radius: 12px; background: white;
            display: flex; align-items: center; justify-content: center; font-weight: 600;
            transition: 0.2s;
        }
        .btn-google:hover { background: #f8f9fa; border-color: #ccc; }

        .brand-text { font-size: 4.5rem; font-weight: 800; line-height: 1; margin-bottom: 20px; }
        .welcome-text { font-size: 2.8rem; font-weight: 700; margin-top: 10px; }
        .sub-text { font-size: 1.2rem; opacity: 0.85; margin-bottom: 10px; }
        
        .signup-prompt {
            margin-top: 30px;
            padding-top: 20px;
            border-top: 1px solid #eee;
        }
        .signup-link {
            color: #702082;
            font-weight: 700;
            text-decoration: none;
        }
        .signup-link:hover { text-decoration: underline; }
    </style>
</head>
<body>
    <div class="container-fluid p-0">
        <div class="row full-row g-0">
            <div class="col-lg-6 brand-side d-none d-lg-flex">
                <div class="mb-4"><i class="bi bi-mortarboard-fill" style="font-size: 4rem;"></i></div>
                <h1 class="brand-text">Student Brain<br>Trust</h1>
                <h2 class="welcome-text">Unlock Solutions.</h2>
                <p class="sub-text">Collaborate with peers, solve complex doubts, and learn together in a smarter way.</p>
            </div>

            <div class="col-lg-6 d-flex align-items-center justify-content-center bg-white p-5">
                <div style="width: 100%; max-width: 420px;">
                    <div class="mb-5 d-lg-none text-center">
                         <h2 class="fw-bold" style="color: #1e3c72;">Student Brain Trust</h2>
                    </div>

                    <form asp-action="Login" method="post">
                        <label class="fw-bold mb-2 small text-muted">STUDENT EMAIL</label>
                        <input type="email" asp-for="Email" name="Email" class="form-control form-control-lg" placeholder="e.g. student@symbiosis.edu" required>
                        
                        <label class="fw-bold mb-2 small text-muted">PASSWORD</label>
                        <div class="position-relative">
                            <input type="password" asp-for="Password" name="Password" class="form-control form-control-lg" placeholder="••••••••" required>
                            <i class="bi bi-eye-slash position-absolute top-50 end-0 translate-middle-y me-3 text-muted" style="margin-top: -10px; cursor: pointer;"></i>
                        </div>

                        <div class="text-end mb-4">
                            <a href="#" class="text-muted small text-decoration-none">Forgot password?</a>
                        </div>

                        <button type="submit" class="btn btn-primary btn-login w-100 text-white">Login</button>
                        
                        <div class="text-center my-4 text-muted small fw-bold">OR LOGIN WITH</div>

                        <button type="button" class="btn btn-google w-100 mb-4">
                            <img src="https://www.gstatic.com/images/branding/product/2x/googleg_48dp.png" height="20" class="me-2">
                            Google
                        </button>

                        <div class="text-center signup-prompt">
                            <span class="text-muted small">New to the platform?</span><br>
                            <a asp-controller="Account" asp-action="Register" class="signup-link">Create an Account for Free</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</body>
</html>