@model StudentDoubtSolver.Models.Question

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Post a Doubt | Brain Trust</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --glass: rgba(255, 255, 255, 0.9);
            --primary-grad: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
            --accent-purple: #702082;
        }

        body { 
            background: radial-gradient(circle at top left, #fdfcfb 0%, #e2d1c3 100%); 
            font-family: 'Poppins', sans-serif; 
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            padding: 20px;
        }

        /* Floating Glass Card */
        .create-card {
            background: var(--glass);
            backdrop-filter: blur(20px);
            border-radius: 35px;
            padding: 50px;
            width: 100%;
            max-width: 650px;
            border: 1px solid rgba(255,255,255,0.7);
            box-shadow: 0 25px 60px rgba(0,0,0,0.1);
            border-top: 10px solid var(--accent-purple);
            animation: slideUp 0.6s ease-out;
        }

        @@keyframes slideUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .icon-header {
            width: 70px; height: 70px;
            background: #f0f4ff;
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 25px;
            color: var(--accent-purple);
            font-size: 2.2rem;
            box-shadow: 0 10px 20px rgba(112, 32, 130, 0.1);
        }

        .form-label {
            font-weight: 700;
            color: #444;
            text-transform: uppercase;
            font-size: 0.8rem;
            letter-spacing: 0.5px;
            margin-bottom: 10px;
        }

        .form-control {
            border-radius: 18px;
            padding: 16px;
            border: 2px solid #eee;
            background: rgba(255, 255, 255, 0.8);
            transition: all 0.3s ease;
            font-size: 1rem;
        }

        .form-control:focus {
            border-color: var(--accent-purple);
            background: #fff;
            box-shadow: 0 0 20px rgba(112, 32, 130, 0.1);
            outline: none;
        }

        .btn-broadcast {
            background: var(--primary-grad);
            color: white;
            border: none;
            border-radius: 50px;
            padding: 18px;
            font-weight: 700;
            width: 100%;
            margin-top: 25px;
            font-size: 1.1rem;
            box-shadow: 0 10px 25px rgba(30, 60, 114, 0.3);
            transition: 0.3s;
        }

        .btn-broadcast:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 30px rgba(30, 60, 114, 0.4);
            color: white;
        }

        .back-btn {
            text-decoration: none;
            color: #888;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            margin-bottom: 30px;
            transition: 0.3s;
        }

        .back-btn:hover {
            color: var(--accent-purple);
            transform: translateX(-5px);
        }
    </style>
</head>
<body>

    <div class="create-card">
        <a asp-action="Index" class="back-btn">
            <i class="bi bi-arrow-left-circle-fill me-2 fs-5"></i> Back to Dashboard
        </a>

        <div class="icon-header">
            <i class="bi bi-patch-question-fill"></i>
        </div>
        
        <h2 class="fw-bold text-dark mb-1">Stuck on something?</h2>
        <p class="text-muted mb-5">Describe your doubt clearly so the community can provide the best solution.</p>

        <form asp-action="Create" method="post">
            <div class="mb-4">
                <label class="form-label">Headline of your doubt</label>
                <input asp-for="Title" class="form-control" placeholder="e.g., Error CS1002 in C# Controller" required />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Detailed Explanation</label>
                <textarea asp-for="Description" class="form-control" rows="6" placeholder="Provide context, error messages, or what you've tried..." required></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-broadcast">
                <i class="bi bi-megaphone-fill me-2"></i> Broadcast Doubt
            </button>
        </form>
    </div>

</body>
</html>